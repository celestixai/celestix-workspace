enum AuditAction {
  USER_CREATED
  USER_DISABLED
  USER_ENABLED
  PASSWORD_RESET
  SETTINGS_CHANGED
  QUOTA_CHANGED
  FORM_CREATED
  BOOKING_CREATED
  WORKFLOW_EXECUTED
  LIST_CREATED
  VIDEO_UPLOADED
  DOCUMENT_SHARED
  DOCUMENT_COMMENT
  SPREADSHEET_SHARED
  PRESENTATION_SHARED
  TODO_REMINDER
  TODO_ASSIGNED
  SOCIAL_POST_REPLY
  SOCIAL_PRAISE
  SOCIAL_MENTION
  NEWS_PUBLISHED
  SITE_UPDATE
}

enum StatusGroup {
  NOT_STARTED
  ACTIVE
  DONE
  CLOSED
}

enum InboxItemType {
  TASK_ASSIGNED
  TASK_MENTIONED
  COMMENT_ASSIGNED
  COMMENT_MENTION
  STATUS_CHANGED
  DUE_DATE_REMINDER
  CUSTOM_REMINDER
  WATCHER_UPDATE
  FOLLOW_UP
}

enum InboxCategory {
  PRIMARY
  OTHER
  LATER
}

enum SpaceRole {
