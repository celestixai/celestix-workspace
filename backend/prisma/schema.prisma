  id        String   @id @default(uuid()) @db.Uuid
  itemId    String   @map("item_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  columnId  String   @map("column_id") @db.Uuid
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  changedAt DateTime @default(now()) @map("changed_at")

  item   ListItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  column ListColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@index([itemId, changedAt])
  @@map("list_item_history")
}

// ==========================================
// LOOP COMPONENTS MODULE
// ==========================================

enum LoopComponentType {
  TABLE
  TASK_LIST
  VOTING_TABLE
  STATUS_TRACKER
  QA
  BULLETED_LIST
  NUMBERED_LIST
  PARAGRAPH
  CODE_SNIPPET
  DIVIDER
  REACTION_BAR
}

model LoopComponent {
  id          String            @id @default(uuid()) @db.Uuid
  type        LoopComponentType
  content     Json              @default("{}")
  createdBy   String            @map("created_by") @db.Uuid
  workspaceId String?           @map("workspace_id") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  creator User        @relation(fields: [createdBy], references: [id])
  embeds  LoopEmbed[]

  @@map("loop_components")
}

model LoopPage {
  id           String   @id @default(uuid()) @db.Uuid
  title        String   @default("Untitled")
  componentIds Json     @default("[]") @map("component_ids")
  createdBy    String   @map("created_by") @db.Uuid
  workspaceId  String?  @map("workspace_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  creator User @relation(fields: [createdBy], references: [id])

  @@map("loop_pages")
}

model LoopEmbed {
  id          String @id @default(uuid()) @db.Uuid
  componentId String @map("component_id") @db.Uuid
  contextType String @map("context_type") // message, email, note, task, event
  contextId   String @map("context_id") @db.Uuid

  component LoopComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@index([contextType, contextId])
  @@map("loop_embeds")
}

// ==========================================
// WHITEBOARD MODULE
// ==========================================

model Whiteboard {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @default("Untitled Whiteboard")
  userId       String   @map("user_id") @db.Uuid
  workspaceId  String?  @map("workspace_id") @db.Uuid
  canvasData   Json     @default("[]") @map("canvas_data")
  templateId   String?  @map("template_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collaborators WhiteboardCollaborator[]

  @@index([userId])
  @@map("whiteboards")
}

model WhiteboardCollaborator {
  id           String          @id @default(uuid()) @db.Uuid
  whiteboardId String          @map("whiteboard_id") @db.Uuid
  userId       String          @map("user_id") @db.Uuid
  permission   SharePermission @default(VIEW)

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  @@unique([whiteboardId, userId])
  @@map("whiteboard_collaborators")
}

// ==========================================
// STREAM / VIDEO LIBRARY MODULE
// ==========================================

enum VideoPrivacy {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum VideoStatus {
  PROCESSING
  READY
  FAILED
}

model Video {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  channelId       String?      @map("channel_id") @db.Uuid
  title           String
  description     String?
  storagePath     String       @map("storage_path")
  thumbnailPath   String?      @map("thumbnail_path")
  durationSeconds Int?         @map("duration_seconds")
  transcriptText  String?      @map("transcript_text")
  transcriptVtt   String?      @map("transcript_vtt")
  status          VideoStatus  @default(PROCESSING)
  viewCount       Int          @default(0) @map("view_count")
  tags            Json?
  privacy         VideoPrivacy @default(PUBLIC)
  chapters        Json?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel  VideoChannel?   @relation(fields: [channelId], references: [id])
  comments VideoComment[]
  views    VideoView[]

  @@index([userId])
  @@index([channelId])
  @@map("videos")
}

model VideoChannel {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String?  @map("workspace_id") @db.Uuid
  name        String
  description String?
  thumbnail   String?
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  videos Video[]

  @@map("video_channels")
}

model VideoComment {
  id               String   @id @default(uuid()) @db.Uuid
  videoId          String   @map("video_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  body             String
  timestampSeconds Int?     @map("timestamp_seconds")
  parentCommentId  String?  @map("parent_comment_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  video         Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])
  parentComment VideoComment? @relation("VideoCommentReplies", fields: [parentCommentId], references: [id])
  replies       VideoComment[] @relation("VideoCommentReplies")

  @@index([videoId, createdAt])
  @@map("video_comments")
}

model VideoView {
  id             String   @id @default(uuid()) @db.Uuid
  videoId        String   @map("video_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  watchedSeconds Int      @default(0) @map("watched_seconds")
  lastWatchedAt  DateTime @default(now()) @map("last_watched_at")

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@map("video_views")
}

model Playlist {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String?
  videoIds    Json     @default("[]") @map("video_ids")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("playlists")
}

// ==========================================
// AUTOMATION / WORKFLOWS MODULE
// ==========================================

enum WorkflowStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Workflow {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  workspaceId String?  @map("workspace_id") @db.Uuid
  name        String
  description String?
  trigger     Json
  actions     Json     @default("[]")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  lastRunAt   DateTime? @map("last_run_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs WorkflowRun[]

  @@index([userId])
  @@map("workflows")
}

model WorkflowRun {
  id            String         @id @default(uuid()) @db.Uuid
  workflowId    String         @map("workflow_id") @db.Uuid
  triggerData   Json?          @map("trigger_data")
  status        WorkflowStatus @default(RUNNING)
  startedAt     DateTime       @default(now()) @map("started_at")
  completedAt   DateTime?      @map("completed_at")
  errorMessage  String?        @map("error_message")
  actionResults Json?          @map("action_results")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, startedAt])
  @@map("workflow_runs")
}

// ==========================================
// DASHBOARD MODULE
// ==========================================

model DashboardLayout {
  id      String @id @default(uuid()) @db.Uuid
  userId  String @unique @map("user_id") @db.Uuid
  widgets Json   @default("[]")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dashboard_layouts")
}

// ==========================================
// MESSENGER ENHANCEMENTS
// ==========================================

model Poll {
  id           String   @id @default(uuid()) @db.Uuid
  chatId       String   @map("chat_id") @db.Uuid
  messageId    String?  @map("message_id") @db.Uuid
  creatorId    String   @map("creator_id") @db.Uuid
  question     String
  options      Json
  isMultiVote  Boolean  @default(false) @map("is_multi_vote")
  isAnonymous  Boolean  @default(false) @map("is_anonymous")
  isQuiz       Boolean  @default(false) @map("is_quiz")
  correctOption Int?    @map("correct_option")
  closesAt     DateTime? @map("closes_at")
  isClosed     Boolean  @default(false) @map("is_closed")
  createdAt    DateTime @default(now()) @map("created_at")

  votes PollVote[]

  @@map("polls")
}

model PollVote {
  id          String   @id @default(uuid()) @db.Uuid
  pollId      String   @map("poll_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  optionIndex Int      @map("option_index")
  createdAt   DateTime @default(now()) @map("created_at")

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionIndex])
  @@map("poll_votes")
}

model SavedMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  contextType String @map("context_type") // messenger, workspace
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, messageId, contextType])
  @@index([userId])
  @@map("saved_messages")
}

model ChatFolder {
  id      String @id @default(uuid()) @db.Uuid
  userId  String @map("user_id") @db.Uuid
  name    String
  chatIds Json   @default("[]") @map("chat_ids")
  position Int   @default(0)

  @@index([userId])
  @@map("chat_folders")
}

model ScheduledMessage {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  chatId      String?  @map("chat_id") @db.Uuid
  channelId   String?  @map("channel_id") @db.Uuid
  content     String
  contentHtml String?  @map("content_html")
  scheduledAt DateTime @map("scheduled_at")
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([scheduledAt, sent])
  @@map("scheduled_messages")
}

// ==========================================
