  ADMIN
  MEMBER
  GUEST
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  MONEY
  DROPDOWN
  MULTI_SELECT
  LABEL
  DATE
  CHECKBOX
  EMAIL
