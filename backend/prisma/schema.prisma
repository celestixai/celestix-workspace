// ==========================================
// USERS & AUTH
// ==========================================

model User {
  id              String      @id @default(uuid()) @db.Uuid
  email           String      @unique
  username        String      @unique
  passwordHash    String      @map("password_hash")
  displayName     String      @map("display_name")
  firstName       String?     @map("first_name")
  lastName        String?     @map("last_name")
  avatarUrl       String?     @map("avatar_url")
  bio             String?
  phone           String?
  timezone        String      @default("UTC")
  language        String      @default("en")
  status          UserStatus  @default(OFFLINE)
  customStatus    String?     @map("custom_status")
  customStatusEmoji String?   @map("custom_status_emoji")
  lastSeenAt      DateTime?   @map("last_seen_at")
  isAdmin         Boolean     @default(false) @map("is_admin")
  is2FAEnabled    Boolean     @default(false) @map("is_2fa_enabled")
  totpSecret      String?     @map("totp_secret")
  theme           String      @default("dark")
  accentColor     String      @default("#4F8EF7") @map("accent_color")
  fontSize        Int         @default(14) @map("font_size")
  compactMode     Boolean     @default(false) @map("compact_mode")
  showOnlineStatus Boolean    @default(true) @map("show_online_status")
  showReadReceipts Boolean    @default(true) @map("show_read_receipts")
  showLastSeen    Boolean     @default(true) @map("show_last_seen")
  storageUsed     BigInt      @default(0) @map("storage_used")
  storageQuota    BigInt      @default(5368709120) @map("storage_quota")
  navOrder        Json?       @map("nav_order")
  notificationPrefs Json?     @map("notification_prefs")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  sessions          Session[]
  chatMembers       ChatMember[]
  messages          Message[]
  messageReactions  MessageReaction[]
  workspaceMembers  WorkspaceMember[]
  wsMessages        WsMessage[]
  wsReactions       WsMessageReaction[]
  emails            Email[]
  emailAccounts     EmailAccount[]
  calendars         Calendar[]
  eventAttendees    EventAttendee[]
  projects          ProjectMember[]
  tasks             Task[]            @relation("TaskCreator")
  assignedTasks     TaskAssignee[]
  taskComments      TaskComment[]
  timeEntries       TimeEntry[]
  files             File[]
  notes             Note[]
  noteFolders       NoteFolder[]
  noteTags          NoteTag[]
  contacts          Contact[]
  meetings          Meeting[]         @relation("MeetingHost")
  meetingParticipants MeetingParticipant[]
  notifications     Notification[]
  sentNotifications Notification[]    @relation("NotificationSender")
  auditLogs         AuditLog[]
  bookingPages      BookingPage[]
  appointments      Appointment[]     @relation("AppointmentStaff")
  forms             Form[]
  formResponses     FormResponse[]
  lists             CxList[]
  listItems         ListItem[]
  loopComponents    LoopComponent[]
  loopPages         LoopPage[]
  whiteboards       Whiteboard[]
  videos            Video[]
  videoComments     VideoComment[]
  workflows         Workflow[]
  dashboardLayout   DashboardLayout?
  // Additional #2 relations
  documents         Document[]
  docComments       DocumentComment[]
  docCollaborators  DocumentCollaborator[]
  spreadsheets      Spreadsheet[]
  presentations     Presentation[]
  pdfAnnotations    PdfAnnotation[]
  diagrams          Diagram[]
  analyticsReports  AnalyticsReport[]
  dataSources       DataSource[]
  todoLists         TodoList[]
  todoItems         TodoItem[]
  videoProjects     VideoProject[]
  designs           Design[]
  sites             Site[]
  sitePages         SitePage[]        @relation("SitePageCreator")
  newsPosts         NewsPost[]
  newsComments      NewsComment[]
  communities       CommunityMember[]
  socialPosts       SocialPost[]
  socialComments    SocialComment[]
  createdInvites    WorkspaceInvite[] @relation("WorkspaceInviteCreator")
  createdSpaces     Space[]           @relation("SpaceCreator")
  spaceMembers      SpaceMember[]
  createdFolders    Folder[]          @relation("FolderCreator")
  createdTaskLists  TaskList[]        @relation("TaskListCreator")
  checklistItemAssignments ChecklistItem[] @relation("ChecklistItemAssignee")
  sharedItemsCreated  SharedItem[]  @relation("SharedItemCreator")
  sharedItemsReceived SharedItem[]  @relation("SharedItemRecipient")
  publicLinksCreated  PublicLink[]  @relation("PublicLinkCreator")
  customFieldsCreated CustomFieldDefinition[] @relation("CustomFieldCreator")
  taskRelationshipsCreated TaskRelationship[] @relation("TaskRelationshipCreator")
  taskTemplatesCreated TaskTemplate[] @relation("TaskTemplateCreator")
  taskWatching         TaskWatcher[]
  workspaceTagsCreated WorkspaceTag[] @relation("WorkspaceTagCreator")
  taskTimeEstimates    TaskTimeEstimate[]
  savedViews           SavedView[]       @relation("SavedViewCreator")
  automationsCreated   Automation[]      @relation("AutomationCreator")
  goalFoldersCreated   GoalFolder[]      @relation("GoalFolderCreator")
  goalsCreated         Goal[]            @relation("GoalCreator")
  goalMemberships      GoalMember[]
  customDashboards     DashboardCustom[]  @relation("DashboardCreator")
  inboxItems           InboxItem[]
  reminders            Reminder[]
  postsCreated         Post[]            @relation("PostAuthor")
  postComments         PostComment[]     @relation("PostCommentAuthor")
  followUpsAssigned    FollowUp[]        @relation("FollowUpAssignee")
  followUpsCreated     FollowUp[]        @relation("FollowUpAssigner")
  syncUpsStarted       SyncUp[]          @relation("SyncUpStarter")
  syncUpParticipations SyncUpParticipant[]
  docCommentsEnhanced  DocCommentEnhanced[] @relation("DocCommentEnhancedAuthor")
  docTemplatesCreated  DocTemplate[]     @relation("DocTemplateCreator")
  clipsCreated         Clip[]            @relation("ClipCreator")
  workScheduleAssignments UserWorkSchedule[]
  timeOffRequests      TimeOff[]         @relation("TimeOffRequests")
  timeOffApprovals     TimeOff[]         @relation("TimeOffApprover")
  integrationsConnected Integration[]    @relation("IntegrationConnector")
  teamsCreated         Team[]            @relation("TeamCreator")
  teamMemberships      TeamMember[]

  @@map("users")
}

model Session {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  token       String   @unique
  deviceInfo  String?  @map("device_info")
  ipAddress   String?  @map("ip_address")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ==========================================
// MESSENGER MODULE
// ==========================================

model Chat {
  id          String   @id @default(uuid()) @db.Uuid
  type        ChatType
  name        String?
  description String?
  avatarUrl   String?  @map("avatar_url")
  inviteLink  String?  @unique @map("invite_link")
  isPinned    Boolean  @default(false) @map("is_pinned")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members     ChatMember[]
  messages    Message[]
  pinnedMessages Message[] @relation("PinnedMessages")

  @@map("chats")
}

model ChatMember {
  id         String     @id @default(uuid()) @db.Uuid
  chatId     String     @map("chat_id") @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  role       MemberRole @default(MEMBER)
  isMuted    Boolean    @default(false) @map("is_muted")
  isPinned   Boolean    @default(false) @map("is_pinned")
  lastReadMessageId String? @map("last_read_message_id") @db.Uuid
  joinedAt   DateTime   @default(now()) @map("joined_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
  @@map("chat_members")
}

model Message {
  id          String   @id @default(uuid()) @db.Uuid
  chatId      String   @map("chat_id") @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  content     String?
  contentHtml String?  @map("content_html")
  replyToId   String?  @map("reply_to_id") @db.Uuid
  forwardedFromId String? @map("forwarded_from_id") @db.Uuid
  isPinned    Boolean  @default(false) @map("is_pinned")
  isEdited    Boolean  @default(false) @map("is_edited")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  deletedForAll Boolean @default(false) @map("deleted_for_all")
  attachments Json?
  linkPreview Json?    @map("link_preview")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User     @relation(fields: [senderId], references: [id])
  replyTo     Message? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[] @relation("MessageReplies")
  forwardedFrom Message? @relation("MessageForwards", fields: [forwardedFromId], references: [id])
  forwards    Message[] @relation("MessageForwards")
  pinnedInChat Chat?   @relation("PinnedMessages", fields: [chatId], references: [id], map: "pinned_messages_fk")
  reactions   MessageReaction[]
  versions    MessageVersion[]
  readReceipts MessageReadReceipt[]

  @@index([chatId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model MessageVersion {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  content   String
  editedAt  DateTime @default(now()) @map("edited_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_versions")
}

model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

model MessageReadReceipt {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  readAt    DateTime @default(now()) @map("read_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_read_receipts")
}

// ==========================================
// WORKSPACE MODULE
// ==========================================

model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  iconUrl     String?  @map("icon_url")
  inviteCode  String?  @unique @map("invite_code")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members     WorkspaceMember[]
  channels    WsChannel[]
  customEmojis WsCustomEmoji[]
  invites     WorkspaceInvite[]
  spaces      Space[]
  customFieldDefinitions CustomFieldDefinition[]
  taskTemplates TaskTemplate[]
  tags          WorkspaceTag[]
  savedViews    SavedView[]
  automations   Automation[]
  goalFolders   GoalFolder[]
  goals         Goal[]
  customDashboards DashboardCustom[]
  docTemplates     DocTemplate[]
  clips            Clip[]
  workSchedules    WorkSchedule[]
  integrations     Integration[]
  teams            Team[]

  @@map("workspaces")
}

model WorkspaceInvite {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  token       String    @unique @db.VarChar(20)
  createdBy   String    @map("created_by") @db.Uuid
  expiresAt   DateTime? @map("expires_at")
  maxUses     Int?      @map("max_uses")
  useCount    Int       @default(0) @map("use_count")
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("WorkspaceInviteCreator", fields: [createdBy], references: [id])

  @@map("workspace_invites")
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Integration {
  id            String          @id @default(uuid()) @db.Uuid
  workspaceId   String          @map("workspace_id") @db.Uuid
  type          IntegrationType
  name          String
  config        Json?
  isActive      Boolean         @default(true) @map("is_active")
  lastSyncAt    DateTime?       @map("last_sync_at")
  syncStatus    String?         @map("sync_status")
  connectedById String          @map("connected_by_id") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connectedBy User      @relation("IntegrationConnector", fields: [connectedById], references: [id])

  @@map("integrations")
}

model WsChannel {
  id           String      @id @default(uuid()) @db.Uuid
  workspaceId  String      @map("workspace_id") @db.Uuid
  name         String
  description  String?
  topic        String?
  type         ChannelType @default(PUBLIC)
  isArchived   Boolean     @default(false) @map("is_archived")
  createdById  String      @map("created_by_id") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  workspace  Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members    WsChannelMember[]
  messages   WsMessage[]
  bookmarks  WsChannelBookmark[]
  posts      Post[]
  followUps  FollowUp[]
  syncUps    SyncUp[]

  @@unique([workspaceId, name])
  @@map("ws_channels")
}

model WsChannelMember {
  id              String   @id @default(uuid()) @db.Uuid
  channelId       String   @map("channel_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  role            MemberRole @default(MEMBER)
  isStarred       Boolean  @default(false) @map("is_starred")
  isMuted         Boolean  @default(false) @map("is_muted")
  notificationPref String  @default("all") @map("notification_pref")
  lastReadAt      DateTime? @map("last_read_at")
  joinedAt        DateTime @default(now()) @map("joined_at")

  channel WsChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@map("ws_channel_members")
}

model WsMessage {
  id              String   @id @default(uuid()) @db.Uuid
  channelId       String   @map("channel_id") @db.Uuid
  senderId        String   @map("sender_id") @db.Uuid
  parentMessageId String?  @map("parent_message_id") @db.Uuid
  content         String?
  contentHtml     String?  @map("content_html")
  isEdited        Boolean  @default(false) @map("is_edited")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  isFollowUp      Boolean  @default(false) @map("is_follow_up")
  attachments     Json?
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  channel       WsChannel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender        User               @relation(fields: [senderId], references: [id])
  parentMessage WsMessage?         @relation("WsThreadReplies", fields: [parentMessageId], references: [id])
  threadReplies WsMessage[]        @relation("WsThreadReplies")
  reactions     WsMessageReaction[]
  mentions      WsMention[]
  bookmarks     WsMessageBookmark[]
  followUps     FollowUp[]

  @@index([channelId, createdAt])
  @@index([parentMessageId])
  @@map("ws_messages")
}

model WsMessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message WsMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("ws_message_reactions")
}

model WsMention {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @default("user") // user, channel, here

  message WsMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ws_mentions")
}

model WsChannelBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  channelId String   @map("channel_id") @db.Uuid
  title     String
  url       String
  addedById String   @map("added_by_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  channel WsChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("ws_channel_bookmarks")
}

model WsMessageBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  message WsMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("ws_message_bookmarks")
}

model WsCustomEmoji {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String
  imageUrl    String   @map("image_url")
  addedById   String   @map("added_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@map("ws_custom_emojis")
}

// ==========================================
// SYNCUPS (Video/Audio in Chat)
// ==========================================

model SyncUp {
  id             String       @id @default(uuid()) @db.Uuid
  channelId      String       @map("channel_id") @db.Uuid
  startedById    String       @map("started_by_id") @db.Uuid
  title          String?
  status         SyncUpStatus @default(ACTIVE)
  startedAt      DateTime     @default(now()) @map("started_at")
  endedAt        DateTime?    @map("ended_at")
  recordingUrl   String?      @map("recording_url")
  transcriptText String?      @map("transcript_text")
  transcriptJson Json?        @map("transcript_json")
  createdAt      DateTime     @default(now()) @map("created_at")

  channel      WsChannel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  startedBy    User                @relation("SyncUpStarter", fields: [startedById], references: [id])
  participants SyncUpParticipant[]

  @@index([channelId, status])
