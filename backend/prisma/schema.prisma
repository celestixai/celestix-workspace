  ENDED
}

enum IntegrationType {
  GOOGLE_CALENDAR
  OUTLOOK_CALENDAR
  SLACK
  GITHUB
  GOOGLE_DRIVE
  WEBHOOK_INCOMING
  WEBHOOK_OUTGOING
