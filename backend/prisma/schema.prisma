  RELATIONSHIP
  FORMULA
  ROLLUP
  LOCATION
  VOTING
  PEOPLE
  AI_SUMMARY
  AI_SENTIMENT
  AI_CUSTOM
}

enum TemplateType {
  TASK
  LIST
  FOLDER
  SPACE
}

enum HierarchyLevel {
  WORKSPACE
  SPACE
  FOLDER
  LIST
}

enum AutomationLogStatus {
  SUCCESS
  PARTIAL_FAILURE
  FAILURE
}

enum ViewType {
  LIST
  BOARD
  TABLE
  CALENDAR
  GANTT
  TIMELINE
  WORKLOAD
  MIND_MAP
  MAP
  TEAM
