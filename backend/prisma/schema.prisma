  replies       PostComment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@map("post_comments")
}

model FollowUp {
  id            String         @id @default(uuid()) @db.Uuid
  messageId     String         @map("message_id") @db.Uuid
  channelId     String         @map("channel_id") @db.Uuid
  assignedToId  String         @map("assigned_to_id") @db.Uuid
  assignedById  String         @map("assigned_by_id") @db.Uuid
  status        FollowUpStatus @default(PENDING)
  dueDate       DateTime?      @map("due_date")
  note          String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  message    WsMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channel    WsChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  assignedTo User      @relation("FollowUpAssignee", fields: [assignedToId], references: [id])
  assignedBy User      @relation("FollowUpAssigner", fields: [assignedById], references: [id])

  @@index([assignedToId, status])
  @@index([channelId])
  @@map("follow_ups")
}

// ==========================================
// CLIPS MODULE
// ==========================================

model Clip {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  createdById    String    @map("created_by_id") @db.Uuid
  title          String
  type           ClipType
  duration       Int?
  fileUrl        String    @map("file_url")
  thumbnailUrl   String?   @map("thumbnail_url")
  transcriptText String?   @map("transcript_text")
  transcriptJson Json?     @map("transcript_json")
  fileSize       BigInt?   @map("file_size")
  mimeType       String    @map("mime_type")
  isPublic       Boolean   @default(false) @map("is_public")
  viewCount      Int       @default(0) @map("view_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("ClipCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([createdById])
  @@map("clips")
}

// ==========================================
// SPRINT MANAGEMENT (Enhanced)
// ==========================================

model SprintFolder {
  id              String   @id @default(uuid()) @db.Uuid
  spaceId         String   @map("space_id") @db.Uuid
  name            String
  description     String?
  defaultDuration Int      @default(14) @map("default_duration")
  isActive        Boolean  @default(true) @map("is_active")
  position        Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  space   Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  sprints SprintEnhanced[]

  @@index([spaceId])
  @@map("sprint_folders")
}

model SprintEnhanced {
  id              String       @id @default(uuid()) @db.Uuid
  sprintFolderId  String       @map("sprint_folder_id") @db.Uuid
  listId          String?      @map("list_id") @db.Uuid
  name            String
  goal            String?
  status          SprintStatus @default(PLANNING)
  startDate       DateTime     @map("start_date")
  endDate         DateTime     @map("end_date")
  totalPoints     Float        @default(0) @map("total_points")
  completedPoints Float        @default(0) @map("completed_points")
  velocity        Float?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  folder        SprintFolder       @relation(fields: [sprintFolderId], references: [id], onDelete: Cascade)
  tasks         Task[]
  historyPoints SprintHistoryPoint[]

  @@index([sprintFolderId])
  @@index([status])
  @@map("sprints_enhanced")
}

model SprintHistoryPoint {
  id              String   @id @default(uuid()) @db.Uuid
  sprintId        String   @map("sprint_id") @db.Uuid
  date            DateTime
  remainingPoints Float    @map("remaining_points")
  completedPoints Float    @map("completed_points")
  totalTasks      Int      @map("total_tasks")
  completedTasks  Int      @map("completed_tasks")
  addedTasks      Int      @default(0) @map("added_tasks")
  removedTasks    Int      @default(0) @map("removed_tasks")

  sprint SprintEnhanced @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@index([sprintId, date])
  @@map("sprint_history_points")
}

// ==========================================
// WORK SCHEDULES & TIME OFF
// ==========================================

model WorkSchedule {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  name            String
  isDefault       Boolean  @default(false) @map("is_default")
  workDays        Json     @map("work_days")
  workHoursPerDay Float    @default(8) @map("work_hours_per_day")
  startTime       String   @default("09:00") @map("start_time")
  endTime         String   @default("17:00") @map("end_time")
  timezone        String   @default("UTC")
  createdAt       DateTime @default(now()) @map("created_at")

  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userAssignments UserWorkSchedule[]

  @@map("work_schedules")
}

model UserWorkSchedule {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  scheduleId    String    @map("schedule_id") @db.Uuid
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule WorkSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([userId, scheduleId, effectiveFrom])
  @@map("user_work_schedules")
}

model TimeOff {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  type         TimeOffType
  startDate    DateTime      @map("start_date")
  endDate      DateTime      @map("end_date")
  isHalfDay    Boolean       @default(false) @map("is_half_day")
  note         String?
  status       TimeOffStatus @default(APPROVED)
  approvedById String?       @map("approved_by_id") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")

  user       User  @relation("TimeOffRequests", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User? @relation("TimeOffApprover", fields: [approvedById], references: [id])

  @@map("time_off")
}

// ==========================================
// TEAMS MODULE
// ==========================================

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String
  description String?
  color       String?
  icon        String?
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("TeamCreator", fields: [createdById], references: [id])
  members   TeamMember[]

  @@index([workspaceId])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(uuid()) @db.Uuid
  teamId   String   @map("team_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}
