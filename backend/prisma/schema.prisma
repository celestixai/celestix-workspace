// ==========================================
// CALENDAR ENHANCEMENTS
// ==========================================

model Resource {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  type        String   @default("room") // room, equipment, vehicle
  description String?
  capacity    Int?
  location    String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  bookings ResourceBooking[]

  @@map("resources")
}

model ResourceBooking {
  id         String   @id @default(uuid()) @db.Uuid
  resourceId String   @map("resource_id") @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  bookedBy   String   @map("booked_by") @db.Uuid
  startAt    DateTime @map("start_at")
  endAt      DateTime @map("end_at")
  createdAt  DateTime @default(now()) @map("created_at")

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, startAt, endAt])
  @@map("resource_bookings")
}

// ==========================================
// TASKS ENHANCEMENTS
// ==========================================

model Sprint {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  name      String
  startDate DateTime  @map("start_date")
  endDate   DateTime  @map("end_date")
  goal      String?
  status    String    @default("planned") // planned, active, completed
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([projectId])
  @@map("sprints")
}

model TaskCustomField {
  id        String @id @default(uuid()) @db.Uuid
  projectId String @map("project_id") @db.Uuid
  name      String
  type      String // text, number, dropdown, date
  options   Json?
  position  Int    @default(0)

  @@index([projectId])
  @@map("task_custom_fields")
}
