model Task {
  id              String     @id @default(uuid()) @db.Uuid
  projectId       String     @map("project_id") @db.Uuid
  title           String
  descriptionHtml String?    @map("description_html")
  status          TaskStatus @default(TODO)
  priority        TaskPriority @default(NONE)
  dueDate         DateTime?  @map("due_date")
  parentTaskId    String?    @map("parent_task_id") @db.Uuid
  position        Float      @default(0)
  estimatedMinutes Int?      @map("estimated_minutes")
  createdById     String     @map("created_by_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")
  listId          String?    @map("list_id") @db.Uuid
  statusName      String?    @map("status_name")
  statusColor     String?    @map("status_color")
  taskType        String?    @default("task") @map("task_type")
  taskTypeId      String?    @map("task_type_id") @db.Uuid
  customTaskId    String?    @unique @map("custom_task_id")
  startDate       DateTime?  @map("start_date")
  isSubtask       Boolean    @default(false) @map("is_subtask")
  depth           Int        @default(0)
  coverImageUrl   String?    @map("cover_image_url")
  coverImageColor String?    @map("cover_image_color")
  timeEstimate    Int?       @map("time_estimate")

  // Sprint fields
  sprintId     String?  @map("sprint_id") @db.Uuid
  storyPoints  Float?   @map("story_points")

  // Recurrence fields
  isRecurring         Boolean  @default(false) @map("is_recurring")
  recurrenceConfig    Json?    @map("recurrence_config")
  recurrenceParentId  String?  @map("recurrence_parent_id") @db.Uuid
  recurringScheduleId String?  @map("recurring_schedule_id") @db.Uuid

  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("TaskCreator", fields: [createdById], references: [id])
  parentTask  Task?          @relation("TaskSubtasks", fields: [parentTaskId], references: [id])
  subtasks    Task[]         @relation("TaskSubtasks")
  recurrenceParent    Task?   @relation("TaskRecurrenceInstances", fields: [recurrenceParentId], references: [id])
  recurrenceInstances Task[]  @relation("TaskRecurrenceInstances")
  recurringSchedule   RecurringSchedule? @relation("TaskRecurringSchedule")
  assignees   TaskAssignee[]
  labels      TaskLabel[]
  comments    TaskComment[]
  timeEntries TimeEntry[]
  activities  TaskActivity[]
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependents   TaskDependency[] @relation("TaskDependents")
  list        TaskList?      @relation(fields: [listId], references: [id])
  taskTypeRelation TaskType? @relation(fields: [taskTypeId], references: [id])
  sprintEnhanced SprintEnhanced? @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  checklists  Checklist[]
  listMemberships TaskListMembership[]
  customFieldValues CustomFieldValue[]
  relationshipsAsSource TaskRelationship[] @relation("TaskRelationshipSource")
  relationshipsAsTarget TaskRelationship[] @relation("TaskRelationshipTarget")
  watchers        TaskWatcher[]
  workspaceTags   TaskTag[]
  timeEstimates   TaskTimeEstimate[]

  @@index([projectId, status])
  @@index([dueDate])
  @@index([listId, status])
  @@index([isRecurring])
  @@index([sprintId])
  @@map("tasks")
}

