generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum UserStatus {
  ONLINE
  AWAY
  DND
  OFFLINE
  INVISIBLE
}

enum ChatType {
  DIRECT
  GROUP
  CHANNEL
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum ChannelType {
  PUBLIC
  PRIVATE
  DM
}

enum EmailFolder {
  INBOX
  SENT
  DRAFTS
  ARCHIVE
  TRASH
  SPAM
}

enum RSVPStatus {
  ACCEPTED
  DECLINED
  TENTATIVE
  NO_RESPONSE
}

enum BusyStatus {
  BUSY
  FREE
  TENTATIVE
  OUT_OF_OFFICE
}

enum TaskPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
  NONE
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETE
  CLOSED
}

enum RelationType {
  BLOCKS
  WAITING_ON
  LINKED_TO
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum ScheduleStatus {
  ACTIVE
  PAUSED
  COMPLETED
