# ============================================
# Celestix Workspace — Environment Configuration
# ============================================

# Application
NODE_ENV=development
APP_NAME=Celestix Workspace
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001
FRONTEND_PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://celestix:celestix_secret@localhost:5432/celestix?schema=public
POSTGRES_USER=celestix
POSTGRES_PASSWORD=celestix_secret
POSTGRES_DB=celestix

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Session
SESSION_SECRET=change-this-to-another-random-string

# File Storage
STORAGE_PATH=./storage
MAX_FILE_SIZE=524288000
MAX_AVATAR_SIZE=5242880
USER_STORAGE_QUOTA=5368709120

# Email (SMTP — for sending system emails like password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@celestix.local

# WebRTC / TURN
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=

# Giphy API (for GIF search in messenger)
GIPHY_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 2FA
TOTP_ISSUER=Celestix Workspace
